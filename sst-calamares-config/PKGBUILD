# Maintainer: Erik Dubois <erik.dubois@gmail.com>
pkgname=sst-calamares-config
_pkgname=sst-calamares-config
_destname1="/etc"
_destname2="/usr"
_destnamescript="/usr/bin"
pkgver=26.04
pkgrel=11
pkgdesc="calamares config for sst"
arch=('any')
url="https://github.com/2ndShiftTech/${_pkgname}"
license=('GPL3')
makedepends=('git')
depends=()
conflicts=(sst-calamares-config-next)
provides=("${pkgname}")
options=(!strip !emptydirs)
source=(${_pkgname}::"git+$url")
sha256sums=('SKIP')
install='readme.install'
package() {
	mkdir -p "${pkgdir}${_destname1}"
	cp -r "${srcdir}/${_pkgname}/${_destname1}"* "${pkgdir}"
	mkdir -p "${pkgdir}${_destname2}"
	cp -r "${srcdir}/${_pkgname}/${_destname2}"* "${pkgdir}"
	mkdir -p "${pkgdir}${_destnamescript}"
	cp -r "${srcdir}/${_pkgname}/etc/calamares/pkgbuild/build-calamares" "${pkgdir}${_destnamescript}"
}

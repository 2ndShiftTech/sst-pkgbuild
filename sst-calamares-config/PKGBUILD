pkgname=sst-calamares-config
_pkgname=sst-calamares-config
pkgver=26.05
pkgrel=05
pkgdesc="calamares config for sst"
arch=('any')
url="https://github.com/2ndShiftTech/${_pkgname}"
license=('GPL3')

makedepends=('git')
depends=()

conflicts=(sst-calamares-config-next)
provides=("${pkgname}")

source=("${_pkgname}::git+$url")
sha256sums=('SKIP')

install='readme.install'

build() {
    cd "${srcdir}/${_pkgname}"

    echo "Running build-calamares..."

    if [[ -x "etc/calamares/pkgbuild/build-calamares" ]]; then
        bash "etc/calamares/pkgbuild/build-calamares"
    else
        echo "ERROR: build-calamares not found or not executable"
        exit 1
    fi
}

package() {
    cd "${srcdir}/${_pkgname}"

    # /etc
    if [ -d "etc" ]; then
        mkdir -p "${pkgdir}/etc"
        cp -r etc/. "${pkgdir}/etc/"
    fi

    # /usr
    if [ -d "usr" ]; then
        mkdir -p "${pkgdir}/usr"
        cp -r usr/. "${pkgdir}/usr/"
    fi

    # optional installed script
    if [ -f "etc/calamares/pkgbuild/build-calamares" ]; then
        install -Dm755 \
            "etc/calamares/pkgbuild/build-calamares" \
            "${pkgdir}/usr/bin/build-calamares"
    fi
}